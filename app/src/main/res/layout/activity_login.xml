<?xml version="1.0" encoding="utf-8"?>
    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Заголовок -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="Добро пожаловать!"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@android:color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:text="Войдите, чтобы пользоваться функциями приложения"
                android:textSize="16sp"
                android:textColor="@android:color/darker_gray"
                android:gravity="center" />

            <!-- Метка E-mail -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Вход по E-mail"
                android:textSize="14sp"
                android:textColor="@android:color/black"
                android:layout_marginBottom="4dp" />

            <!-- Поле E-mail -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/emailInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/emailEditText1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="example@mail.com"
                    android:inputType="textEmailAddress"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Метка Пароля -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Пароль"
                android:textSize="14sp"
                android:textColor="@android:color/black"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <!-- Поле Пароля с иконкой показа/скрытия -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/passwordInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:endIconMode="password_toggle"

                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/passwordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Введите пароль"
                    android:inputType="textPassword"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Кнопка Далее -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/loginButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Далее"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                 />

            <!-- Ссылка на регистрацию -->
            <TextView
                android:id="@+id/registerTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Зарегистрироваться"
                android:textSize="14sp"

                android:textStyle="bold" />

            <!-- Разделитель -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="Или войдите с помощью"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray" />

            <!-- Социальные сети -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- VK -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/vkButton"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:layout_marginEnd="16dp"
                    android:text="Войти с VK"
                    android:textSize="14sp"

                    app:iconGravity="textStart"
                    app:cornerRadius="8dp"
                    app:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"
                    app:strokeColor="@android:color/darker_gray"
                    app:strokeWidth="1dp" />

                <!-- Yandex -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/yandexButton"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:text="Войти с Yandex"
                    android:textSize="14sp"

                    app:iconGravity="textStart"
                    app:cornerRadius="8dp"
                    app:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"
                    app:strokeColor="@android:color/darker_gray"
                    app:strokeWidth="1dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

